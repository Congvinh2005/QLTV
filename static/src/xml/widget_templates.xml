<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="QLTV.VnDatetimeField" owl="1">
        <span class="o_field_vn_datetime" t-esc="formattedValue" />
    </t>

    <t t-name="QLTV.VnMoneyField" owl="1">
        <input type="text"
            t-att-placeholder="'0đ'"
            t-att-value="formattedValue"
            t-on-focus="onFocus"
            t-on-blur="onBlur"
            t-on-input="onInput"
            class="o_field_vn_money form-control"
            t-att-readonly="props.readonly ? true : undefined"
        />
    </t>

    <t t-name="QLTV.PasswordToggleField" owl="1">
        <div class="o_field_password_toggle input-group">
            <input type="text"
                t-att-type="type"
                t-att-value="currentValue"
                t-on-input="onInput"
                class="o_input form-control"
                t-att-readonly="props.readonly ? true : undefined"
                t-att-placeholder="props.placeholder"
            />
            <span class="o_input-group-append input-group-append" t-if="!props.readonly">
                <button class="btn btn-outline-secondary border" type="button" t-on-click="togglePassword" tabindex="-1">
                    <i t-att-class="iconClass" />
                </button>
            </span>
        </div>
    </t>
</templates>
