<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_library_loan_kanban" model="ir.ui.view">
        <field name="name">library.loan.kanban</field>
        <field name="model">library.loan</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name" />
                <field name="reader_id" />
                <field name="due_date" />
                <field name="state" />
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_library_loan_card">
                            <strong><field name="name"/></strong>
                            <div><field name="reader_id"/></div>
                            <div><span>Hạn trả: </span><field name="due_date"/></div>
                            <field name="state" widget="badge"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
</odoo>
