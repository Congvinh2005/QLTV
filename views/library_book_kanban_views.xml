<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_library_book_kanban" model="ir.ui.view">
        <field name="name">library.book.kanban</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column">
                <field name="code" />
                <field name="name" />
                <field name="author" />
                <field name="qty_available" />
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_library_book_card">
                            <div class="o_kanban_record_title">
                                <strong><field name="name"/></strong>
                            </div>
                            <div><small><field name="code"/></small></div>
                            <div><field name="author"/></div>
                            <div>
                                <span class="badge badge-pill badge-secondary">Còn: <field name="qty_available"/></span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
</odoo>
