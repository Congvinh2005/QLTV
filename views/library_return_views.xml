<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_library_return_tree" model="ir.ui.view">
        <field name="name">library.return.tree</field>
        <field name="model">library.return</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
                <field name="loan_id" />
                <field name="return_date" />
                <field name="fine_amount" />
            </tree>
        </field>
    </record>

    <record id="view_library_return_form" model="ir.ui.view">
        <field name="name">library.return.form</field>
        <field name="model">library.return</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name" readonly="1" />
                        <field name="loan_id" />
                        <field name="return_date" />
                        <field name="fine_amount" />
                        <field name="currency_id" />
                        <field name="notes" />
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" />
                    <field name="activity_ids" />
                    <field name="message_ids" />
                </div>
            </form>
        </field>
    </record>

    <record id="action_library_return" model="ir.actions.act_window">
        <field name="name">Trả sách</field>
        <field name="res_model">library.return</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
