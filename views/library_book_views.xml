<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_library_book_tree" model="ir.ui.view">
        <field name="name">library.book.tree</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <tree decoration-danger="available_count == 0"
                decoration-warning="available_count &lt;= 2">
                <field name="code" />
                <field name="name" />
                <field name="author" />
                <field name="category" />
                <field name="quantity_total" sum="Tổng số bản" />
                <field name="borrowed_count" sum="Đang mượn" />
                <field name="available_count" sum="Có sẵn" />
                <field name="total_borrow_count" sum="Tổng lượt mượn" />
            </tree>
        </field>
    </record>

    <record id="view_library_book_form" model="ir.ui.view">
        <field name="name">library.book.form</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="cover_image" widget="image" class="oe_avatar" />
                    <group>
                        <group>
                            <field name="code" />
                            <field name="name" />
                            <field name="author" />
                            <field name="category" />
                            <field name="publisher" />
                        </group>
                        <group>
                            <field name="publication_year" />
                            <field name="isbn" />
                            <field name="shelf_location" />
                            <field name="quantity_total" />
                            <field name="available_count" readonly="1" />
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" />
                    <field name="activity_ids" />
                    <field name="message_ids" />
                </div>
            </form>
        </field>
    </record>

    <record id="view_library_book_search" model="ir.ui.view">
        <field name="name">library.book.search</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <field name="code" />
                <field name="author" />
                <field name="publisher" />
                <field name="category" />
                <field name="isbn" />
                <separator />
                <filter name="out_of_stock" string="Hết sách" domain="[('available_count', '=', 0)]" />
                <filter name="available" string="Còn sách" domain="[('available_count', '>', 0)]" />
                <filter name="low_stock" string="Sắp hết" domain="[('available_count', '>', 0), ('available_count', '&lt;=', 2)]" />
                <separator />
                <group expand="0" string="Nhóm theo">
                    <filter name="group_category" string="Thể loại"
                        context="{'group_by': 'category'}" />
                    <filter name="group_author" string="Tác giả" context="{'group_by': 'author'}" />
                    <filter name="group_publisher" string="Nhà xuất bản"
                        context="{'group_by': 'publisher'}" />
                </group>
            </search>
        </field>
    </record>

    <record id="action_library_book" model="ir.actions.act_window">
        <field name="name">Sách</field>
        <field name="res_model">library.book</field>
        <field name="view_mode">tree,form,pivot,graph</field>
        <field name="search_view_id" ref="view_library_book_search" />
    </record>
</odoo>