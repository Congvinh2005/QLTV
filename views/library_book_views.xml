<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_library_book_tree" model="ir.ui.view">
        <field name="name">library.book.tree</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <tree decoration-danger="qty_available == 0"
                decoration-warning="qty_available &lt;= 2">
                <field name="code" />
                <field name="name" />
                <field name="author" />
                <field name="category" />
                <field name="qty_available" sum="Tồn kho" />
                <field name="borrowed_count" sum="Đang mượn" />
            </tree>
        </field>
    </record>

    <record id="view_library_book_form" model="ir.ui.view">
        <field name="name">library.book.form</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_sync_copies_from_stock" type="object"
                        string="Đồng bộ bản sao từ tồn kho"
                        class="btn-primary"
                        attrs="{'invisible': [('product_id', '=', False)]}" />
                </header>
                <sheet>
                    <field name="cover_image" widget="image" class="oe_avatar" />
                    <group>
                        <group>
                            <field name="code" />
                            <field name="name" />
                            <field name="author" />
                            <field name="category" />
                            <field name="publisher" />
                        </group>
                        <group>
                            <field name="publication_year" />
                            <field name="isbn" />
                            <field name="price" />
                            <field name="shelf_location" />
                        </group>
                    </group>
                    <group string="Tồn kho">
                        <group>
                            <field name="qty_available" />
                            <field name="borrowed_count" readonly="1" />
                            <field name="total_copies" />
                        </group>
                        <group>
                            <field name="product_categ_id" />
                            <field name="product_id" readonly="1" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Các bản sao" name="copies">
                            <field name="copy_ids" readonly="0">
                                <tree editable="bottom">
                                    <field name="code" />
                                    <field name="state" widget="badge" />
                                    <field name="loan_line_id" readonly="1" />
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" />
                    <field name="activity_ids" />
                    <field name="message_ids" />
                </div>
            </form>
        </field>
    </record>

    <record id="view_library_book_search" model="ir.ui.view">
        <field name="name">library.book.search</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <field name="code" />
                <field name="author" />
                <field name="publisher" />
                <field name="category" />
                <field name="isbn" />
                <separator />
                <filter name="out_of_stock" string="Hết sách" domain="[('qty_available', '=', 0)]" />
                <filter name="available" string="Còn sách" domain="[('qty_available', '>', 0)]" />
                <filter name="low_stock" string="Sắp hết" domain="[('qty_available', '>', 0), ('qty_available', '&lt;=', 2)]" />
                <separator />
                <group expand="0" string="Nhóm theo">
                    <filter name="group_category" string="Thể loại"
                        context="{'group_by': 'category'}" />
                    <filter name="group_author" string="Tác giả" context="{'group_by': 'author'}" />
                    <filter name="group_publisher" string="Nhà xuất bản"
                        context="{'group_by': 'publisher'}" />
                </group>
            </search>
        </field>
    </record>

    <record id="action_library_book" model="ir.actions.act_window">
        <field name="name">Sách</field>
        <field name="res_model">library.book</field>
        <field name="view_mode">kanban,tree,form,pivot,graph</field>
        <field name="search_view_id" ref="view_library_book_search" />
    </record>
</odoo>
