<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_library_loan_tree" model="ir.ui.view">
        <field name="name">library.loan.tree</field>
        <field name="model">library.loan</field>
        <field name="arch" type="xml">
            <tree decoration-danger="state == 'overdue'" decoration-success="state == 'returned'">
                <field name="name" />
                <field name="reader_id" />
                <field name="borrow_date" widget="vn_datetime" />
                <field name="return_date" widget="vn_datetime" />
                <field name="due_date" widget="vn_datetime" />
                <field name="borrow_fee" widget="vn_money" sum="Phí mượn" />
                <field name="fine_amount" widget="vn_money" sum="Phí phạt" />
                <field name="total_amount" widget="vn_money" sum="Tổng" />
                <field name="state" widget="badge" />
            </tree>
        </field>
    </record>

    <record id="view_library_loan_kanban" model="ir.ui.view">
        <field name="name">library.loan.kanban</field>
        <field name="model">library.loan</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name" />
                <field name="reader_id" />
                <field name="due_date" />
                <field name="state" />
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <strong>
                                <field name="name" />
                            </strong>
                            <div>
                                <field name="reader_id" />
                            </div>
                            <div>Due: <field name="due_date" /></div>
                            <field name="state" widget="badge" />
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_library_loan_form" model="ir.ui.view">
        <field name="name">library.loan.form</field>
        <field name="model">library.loan</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_approve" type="object" string="Duyệt" class="btn-primary"
                        states="draft" />
                    <button name="action_borrow" type="object" string="Mượn" class="btn-primary"
                        states="approved" />
                    <button name="action_return" type="object" string="Trả" class="btn-primary"
                        states="borrowed,overdue" />
                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,approved,borrowed,overdue,returned" />
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1" />
                            <field name="reader_id" />
                            <field name="borrow_date" />
                            <field name="return_date" />
                        </group>
                        <group>
                            <field name="borrow_fee" widget="vn_money" />
                            <field name="fine_amount" widget="vn_money" readonly="1" />
                            <field name="total_amount" widget="vn_money" readonly="1" />
                            <field name="due_date" widget="vn_datetime" readonly="1" />
                            <field name="currency_id" invisible="1" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Sách">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="book_id" />
                                    <field name="state" />
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" />
                    <field name="activity_ids" />
                    <field name="message_ids" />
                </div>
            </form>
        </field>
    </record>

    <record id="view_library_loan_search" model="ir.ui.view">
        <field name="name">library.loan.search</field>
        <field name="model">library.loan</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <field name="reader_id" />
                <field name="borrow_fee" />
                <field name="fine_amount" />
                <field name="total_amount" />
                <filter name="borrowed" string="Đang mượn" domain="[('state', '=', 'borrowed')]" />
                <filter name="returned" string="Đã trả" domain="[('state', '=', 'returned')]" />
                <filter name="overdue" string="Quá hạn" domain="[('state', '=', 'overdue')]" />
                <separator />
                <filter name="filter_today" string="Hôm nay"
                    domain="[('borrow_date', '&gt;=', datetime.datetime.today().replace(hour=0, minute=0, second=0)), ('borrow_date', '&lt;=', datetime.datetime.today().replace(hour=23, minute=59, second=59))]"
                    help="Phiếu mượn trong ngày" />
                <filter name="filter_revenue_today" string="Doanh thu hôm nay"
                    domain="[('return_date', '&gt;=', datetime.datetime.today().replace(hour=0, minute=0, second=0)), ('return_date', '&lt;=', datetime.datetime.today().replace(hour=23, minute=59, second=59)), ('state', 'in', ('returned', 'overdue'))]" />
                <separator />
                <filter name="filter_borrow_date" string="Ngày mượn" date="borrow_date" />
                <filter name="filter_return_date" string="Ngày trả" date="return_date" />
                <group expand="0" string="Nhóm theo">
                    <filter name="group_state" string="Trạng thái" context="{'group_by': 'state'}" />
                    <filter name="group_reader" string="Bạn đọc" context="{'group_by': 'reader_id'}" />
                    <filter name="group_borrow_date" string="Ngày mượn" context="{'group_by': 'borrow_date'}" />
                    <filter name="group_return_date" string="Ngày trả" context="{'group_by': 'return_date'}" />
                </group>
            </search>
        </field>
    </record>

    <record id="action_library_loan" model="ir.actions.act_window">
        <field name="name">Mượn trả</field>
        <field name="res_model">library.loan</field>
        <field name="view_mode">kanban,tree,form,pivot,graph</field>
        <field name="search_view_id" ref="view_library_loan_search" />
    </record>
</odoo>