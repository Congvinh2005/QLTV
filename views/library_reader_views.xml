<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_library_reader_tree" model="ir.ui.view">
        <field name="name">library.reader.tree</field>
        <field name="model">library.reader</field>
        <field name="arch" type="xml">
            <tree>
                <field name="code"/>
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="registration_date"/>
                <field name="total_loan_count"/>
                <field name="current_loan_count"/>
                <field name="overdue_loan_count"/>
            </tree>
        </field>
    </record>

    <record id="view_library_reader_form" model="ir.ui.view">
        <field name="name">library.reader.form</field>
        <field name="model">library.reader</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="email"/>
                            <field name="phone"/>
                        </group>
                        <group>
                            <field name="registration_date"/>
                            <field name="address"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_library_reader" model="ir.actions.act_window">
        <field name="name">Readers</field>
        <field name="res_model">library.reader</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
