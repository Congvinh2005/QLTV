<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_library_reader_tree" model="ir.ui.view">
        <field name="name">library.reader.tree</field>
        <field name="model">library.reader</field>
        <field name="arch" type="xml">
            <tree>
                <field name="code" />
                <field name="name" />
                <field name="email" />
                <field name="phone" />
                <field name="registration_date" />
                <field name="total_loan_count" />
                <field name="current_loan_count" />
                <field name="overdue_loan_count" />
            </tree>
        </field>
    </record>

    <record id="view_library_reader_form" model="ir.ui.view">
        <field name="name">library.reader.form</field>
        <field name="model">library.reader</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="code" />
                            <field name="name" />
                            <field name="email" />
                            <field name="phone" />
                        </group>
                        <group>
                            <field name="registration_date" />
                            <field name="address" />
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" />
                    <field name="activity_ids" />
                    <field name="message_ids" />
                </div>
            </form>
        </field>
    </record>

    <record id="view_library_reader_search" model="ir.ui.view">
        <field name="name">library.reader.search</field>
        <field name="model">library.reader</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <field name="email" />
                <field name="phone" />
                <field name="code" />
                <separator />
                <filter name="filter_borrowing" string="Đang mượn"
                    domain="[('current_loan_count', '>', 0)]" />
                <filter name="filter_overdue" string="Quá hạn"
                    domain="[('overdue_loan_count', '>', 0)]" />
                <separator />
                <group expand="0" string="Nhóm theo">
                    <filter name="group_registration" string="Ngày đăng ký"
                        context="{'group_by': 'registration_date'}" />
                    <filter name="group_user" string="Tài khoản"
                        context="{'group_by': 'user_id'}" />
                </group>
            </search>
        </field>
    </record>

    <record id="action_library_reader" model="ir.actions.act_window">
        <field name="name">Bạn đọc</field>
        <field name="res_model">library.reader</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_library_reader_search" />
    </record>
</odoo>