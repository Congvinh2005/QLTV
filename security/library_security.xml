<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_library" model="ir.module.category">
        <field name="name">Thư viện</field>
        <field name="description">Quản lý thư viện</field>
        <field name="sequence">20</field>
    </record>

    <record id="group_library_reader" model="res.groups">
        <field name="name">Bạn đọc</field>
        <field name="category_id" ref="module_category_library" />
    </record>

    <record id="group_library_user" model="res.groups">
        <field name="name">Nhân viên</field>
        <field name="category_id" ref="module_category_library" />
    </record>

    <record id="group_library_manager" model="res.groups">
        <field name="name">Quản lý</field>
        <field name="category_id" ref="module_category_library" />
        <field name="implied_ids" eval="[(4, ref('group_library_user')), (4, ref('base.group_system'))]" />
    </record>
</odoo>