<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="0">

    <!-- Reader: chỉ thấy thông tin của chính mình -->
    <record id="rule_library_reader_self" model="ir.rule">
        <field name="name">Bạn đọc: chỉ xem thông tin của mình</field>
        <field name="model_id" ref="model_library_reader"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_library_reader'))]"/>
    </record>

    <!-- Reader: chỉ thấy phiếu mượn của mình -->
    <record id="rule_library_loan_self" model="ir.rule">
        <field name="name">Bạn đọc: chỉ xem phiếu mượn của mình</field>
        <field name="model_id" ref="model_library_loan"/>
        <field name="domain_force">[('reader_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_library_reader'))]"/>
    </record>

    <!-- Reader: chỉ thấy dòng sách thuộc phiếu mượn của mình -->
    <record id="rule_library_loan_line_self" model="ir.rule">
        <field name="name">Bạn đọc: chỉ xem dòng mượn của mình</field>
        <field name="model_id" ref="model_library_loan_line"/>
        <field name="domain_force">[('loan_id.reader_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_library_reader'))]"/>
    </record>

</odoo>
