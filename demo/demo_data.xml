<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="user_library_user" model="res.users">
        <field name="login">user</field>
        <field name="password">user</field>
        <field name="name">Nhân viên thư viện</field>
        <field name="groups_id" eval="[(4, ref('group_library_user'))]" />
    </record>

    <record id="user_library_manager" model="res.users">
        <field name="login">manager</field>
        <field name="password">manager</field>
        <field name="name">Quản lý thư viện</field>
        <field name="groups_id" eval="[(4, ref('group_library_user')), (4, ref('group_library_manager'))]" />
    </record>

    <!-- Sách mẫu -->
    <record id="book_1" model="library.book">
        <field name="code">S001</field>
        <field name="name">Lập trình Python cơ bản</field>
        <field name="author">Nguyễn Văn A</field>
        <field name="category">Công nghệ</field>
        <field name="publisher">NXB Khoa học</field>
        <field name="publication_year">2022</field>
        <field name="price">120000</field>
        <field name="shelf_location">Kệ A-01</field>
    </record>

    <record id="book_2" model="library.book">
        <field name="code">S002</field>
        <field name="name">Odoo Development Essentials</field>
        <field name="author">Trần Văn B</field>
        <field name="category">Công nghệ</field>
        <field name="publisher">NXB Đại học</field>
        <field name="publication_year">2023</field>
        <field name="price">250000</field>
        <field name="shelf_location">Kệ A-02</field>
    </record>

    <record id="book_3" model="library.book">
        <field name="code">S003</field>
        <field name="name">Văn học Việt Nam hiện đại</field>
        <field name="author">Lê Thị C</field>
        <field name="category">Văn học</field>
        <field name="publisher">NXB Văn học</field>
        <field name="publication_year">2021</field>
        <field name="price">85000</field>
        <field name="shelf_location">Kệ B-01</field>
    </record>

    <!-- Bạn đọc mẫu (có tài khoản đăng nhập) -->
    <record id="user_library_reader" model="res.users">
        <field name="login">reader</field>
        <field name="password">reader</field>
        <field name="name">Phạm Văn D</field>
        <field name="groups_id" eval="[(4, ref('group_library_reader'))]" />
    </record>

    <record id="reader_1" model="library.reader">
        <field name="code">RD001</field>
        <field name="name">Phạm Văn D</field>
        <field name="email">phamvand@email.com</field>
        <field name="phone">0901234567</field>
        <field name="user_id" ref="user_library_reader" />
    </record>

    <!-- Phiếu mượn quá hạn mẫu -->
    <record id="loan_overdue_demo" model="library.loan">
        <field name="name">LOAN/DEMO/001</field>
        <field name="reader_id" ref="reader_1" />
        <field name="borrow_date">2026-06-01</field>
        <field name="return_date">2026-06-10</field>
        <field name="borrow_fee">15000</field>
        <field name="state">borrowed</field>
    </record>

    <record id="loan_overdue_line_demo" model="library.loan.line">
        <field name="loan_id" ref="loan_overdue_demo" />
        <field name="book_id" ref="book_1" />
    </record>
</odoo>
