<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_library_return_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Phiếu trả sách</h2>
                        <p><strong>Mã phiếu trả:</strong> <span t-field="doc.name"/></p>
                        <p><strong>Phiếu mượn:</strong> <span t-field="doc.loan_id"/></p>
                        <p><strong>Ngày trả:</strong> <span t-field="doc.return_date"/></p>
                        <p><strong>Tiền phạt:</strong> <span t-field="doc.fine_amount"/></p>
                        <p><strong>Ghi chú:</strong> <span t-field="doc.notes"/></p>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
