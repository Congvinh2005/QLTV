<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_library_loan_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Phiếu mượn thư viện</h2>
                        <p>
                            <strong>Mã phiếu:</strong>
                            <span t-field="doc.name" />
                        </p>
                        <p>
                            <strong>Bạn đọc:</strong>
                            <span t-field="doc.reader_id" />
                        </p>
                        <p>
                            <strong>Ngày mượn:</strong>
                            <span t-field="doc.borrow_date" />
                        </p>
                        <p>
                            <strong>Ngày hết hạn:</strong>
                            <span t-field="doc.due_date" />
                        </p>
                        <p>
                            <strong>Ngày trả:</strong>
                            <span t-field="doc.return_date" />
                        </p>
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Mã sách</th>
                                    <th>Tiêu đề</th>
                                    <th>Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="doc.line_ids" t-as="line">
                                    <td>
                                        <span t-field="line.book_id.code" />
                                    </td>
                                    <td>
                                        <span t-field="line.book_id.name" />
                                    </td>
                                    <td>
                                        <span t-field="line.state" />
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <h3>Chi phí</h3>
                        <p>
                            <strong>Phí mượn:</strong>
                            <span t-field="doc.borrow_fee" />
                        </p>
                        <p>
                            <strong>Phí phạt:</strong>
                            <span t-field="doc.fine_amount" />
                        </p>
                        <p>
                            <strong>Tổng tiền:</strong>
                            <span t-field="doc.total_amount" />
                        </p>

                        <h3>Kho</h3>
                        <p>
                            <strong>Phiếu kho:</strong>
                        </p>
                        <table class="table table-sm" t-if="doc.picking_ids">
                            <thead>
                                <tr>
                                    <th>Mã phiếu kho</th>
                                    <th>Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="doc.picking_ids" t-as="p">
                                    <td>
                                        <span t-field="p.name" />
                                    </td>
                                    <td>
                                        <span t-field="p.state" />
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <p t-if="doc.invoice_ids">
                            <strong>Hoá đơn:</strong>
                            <span t-foreach="doc.invoice_ids" t-as="inv" t-separator=", ">
                                <span t-field="inv.name" />
                            </span>
                        </p>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
