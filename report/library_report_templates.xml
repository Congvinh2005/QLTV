<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_library_loan_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Library Loan Slip</h2>
                        <p><strong>Reference:</strong> <span t-field="doc.name"/></p>
                        <p><strong>Reader:</strong> <span t-field="doc.reader_id"/></p>
                        <p><strong>Borrow Date:</strong> <span t-field="doc.borrow_date"/></p>
                        <p><strong>Due Date:</strong> <span t-field="doc.due_date"/></p>
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Book Code</th>
                                    <th>Title</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="doc.line_ids" t-as="line">
                                    <td><span t-field="line.book_id.code"/></td>
                                    <td><span t-field="line.book_id.name"/></td>
                                    <td><span t-field="line.state"/></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
