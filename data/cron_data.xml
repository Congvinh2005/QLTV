<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="seq_library_loan" model="ir.sequence">
        <field name="name">Phiếu mượn thư viện</field>
        <field name="code">library.loan</field>
        <field name="prefix">LOAN/%(year)s/</field>
        <field name="padding">5</field>
    </record>

    <record id="seq_library_book" model="ir.sequence">
        <field name="name">Mã sách thư viện</field>
        <field name="code">library.book</field>
        <field name="prefix">S</field>
        <field name="padding">1</field>
    </record>

    <record id="seq_library_book_category" model="ir.sequence">
        <field name="name">Mã thể loại thư viện</field>
        <field name="code">library.book.category</field>
        <field name="prefix">TL</field>
        <field name="padding">1</field>
    </record>

    <record id="seq_library_reader" model="ir.sequence">
        <field name="name">Mã độc giả thư viện</field>
        <field name="code">library.reader</field>
        <field name="prefix">DG</field>
        <field name="padding">1</field>
    </record>

    <record id="overdue_fee_per_day" model="ir.config_parameter">
        <field name="key">qltv.overdue_fee_per_day</field>
        <field name="value">1000</field>
    </record>

    <record id="stock_location_borrowed" model="stock.location">
        <field name="name">Sách đang mượn</field>
        <field name="usage">internal</field>
        <field name="location_id" ref="stock.stock_location_stock"/>
    </record>

    <record id="ir_cron_library_overdue" model="ir.cron">
        <field name="name">Thư viện: Kiểm tra phiếu mượn quá hạn</field>
        <field name="model_id" ref="model_library_loan" />
        <field name="state">code</field>
        <field name="code">model.action_check_overdue()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
    </record>
</odoo>